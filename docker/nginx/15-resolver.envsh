#!/bin/sh

# The official Nginx entrypoint sources *.envsh files before rendering
# /etc/nginx/templates. Reading the container resolver keeps backend service
# discovery portable across Podman, Docker and QNAP Container Station.
DNS_RESOLVER="$(awk '/^nameserver[[:space:]]+/ { print $2; exit }' /etc/resolv.conf)"
export DNS_RESOLVER="${DNS_RESOLVER:-127.0.0.11}"
